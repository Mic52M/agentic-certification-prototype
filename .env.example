# Copia in .env e completa.
#   cp .env.example .env

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here

# --- Modello ---
# Default: openai/gpt-oss-120b (131K contesto, buono per orchestrazione).
# Alternative valide: qwen/qwen3.6-27b, llama-3.3-70b-versatile.
# MODEL=openai/gpt-oss-120b
# TEMPERATURE=0.0

# --- Demo multi-run ---
# EXPERIMENT_RUNS=10
# EXPERIMENT_DELAY_S=1.0

# --- Legacy ---
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# MAX_ITERATIONS=10
